# --- Supabase (projeto: ivezfeaztisayqatyrkg) -----------------------------
# Público (pode ir para o cliente web/mobile):
NEXT_PUBLIC_SUPABASE_URL=https://ivezfeaztisayqatyrkg.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxx
# Mesmos valores para o app mobile (Expo exige o prefixo EXPO_PUBLIC_):
EXPO_PUBLIC_SUPABASE_URL=https://ivezfeaztisayqatyrkg.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxx

# Secreto (SOMENTE servidor / edge functions / admin — jamais no cliente):
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxx
SUPABASE_DB_URL=postgresql://postgres:[PASSWORD]@db.ivezfeaztisayqatyrkg.supabase.co:5432/postgres

# --- Consultor IA (Claude / Anthropic) ------------------------------------
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx
# Modelo usado pelo Consultor IA e pela geração de embeddings de contexto:
IA_MODEL=claude-sonnet-5
# Embeddings (OpenAI text-embedding-3-small OU Voyage). Escolha um provedor:
EMBEDDINGS_PROVIDER=openai
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxx

# --- Pagamentos / Assinaturas (Stripe) ------------------------------------
# PENDENTE: definir gateway (Stripe x Mercado Pago x Asaas) — ver PENDENCIAS.md
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxx
# IDs de preço criados no painel do Stripe:
STRIPE_PRICE_MENSAL=price_xxxxxxxxxxxxx
STRIPE_PRICE_ANUAL=price_xxxxxxxxxxxxx

# --- E-mail transacional (notificações do dono e do aluno) ----------------
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM="IRTS Academy <no-reply@irts.com.br>"
# Para onde vão as notificações do dono (compra, conclusão, abandono):
OWNER_NOTIFY_EMAIL=newton@exemplo.com.br
# Protege a função pública cron-abandoned (recomendado):
CRON_SECRET=troque-por-um-segredo-aleatorio

# --- URLs públicas --------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="IRTS Academy"
