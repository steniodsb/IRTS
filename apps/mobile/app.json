{
  "expo": {
    "name": "IRTS Academy",
    "slug": "irts-academy",
    "scheme": "irts",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/brand/irts-logo.jpeg",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/brand/irts-logo.jpeg",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "br.com.irts.academy"
    },
    "android": {
      "package": "br.com.irts.academy",
      "adaptiveIcon": {
        "foregroundImage": "./assets/brand/irts-logo.jpeg",
        "backgroundColor": "#0A0A0A"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/brand/irts-logo.jpeg"
    },
    "plugins": ["expo-router", "expo-secure-store"],
    "experiments": {
      "typedRoutes": true,
      "tsconfigPaths": true
    }
  }
}
