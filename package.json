{
  "name": "irts-academy",
  "version": "0.1.0",
  "private": true,
  "description": "IRTS / NDA Academy — área de membros (Web + iOS + Android) para relações trabalhistas e sindicais",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@irts/web",
    "dev:mobile": "turbo run start --filter=@irts/mobile",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@irts/web",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "db:types": "supabase gen types typescript --project-id ivezfeaztisayqatyrkg > packages/shared/src/database.types.ts",
    "db:push": "supabase db push",
    "db:reset": "supabase db reset"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.1.3",
    "typescript": "^5.6.2"
  },
  "pnpm": {
    "overrides": {
      "react": "18.2.0",
      "react-dom": "18.2.0"
    }
  }
}
